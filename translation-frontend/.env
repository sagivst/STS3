# Azure Production Configuration (placeholder - will be updated during deployment)
VITE_API_URL=https://sts3-dev-vm-placeholder.israelcentral.cloudapp.azure.com/api

# Development Configuration (fallback)
# VITE_API_URL=http://localhost:8000

# WebSocket Configuration
VITE_WS_URL=wss://sts3-dev-vm-placeholder.israelcentral.cloudapp.azure.com/ws

# Performance Configuration for Zero Latency
VITE_AUDIO_SAMPLE_RATE=16000
VITE_AUDIO_CHUNK_SIZE=1024
VITE_MAX_RECONNECT_ATTEMPTS=5
VITE_RECONNECT_DELAY=1000

# Azure Region Configuration
VITE_AZURE_REGION=israelcentral
VITE_DEPLOYMENT_REGION=Israel Central
