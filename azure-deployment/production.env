# Production Environment Configuration for Azure Deployment

# Azure Configuration
AZURE_KEY_VAULT_URL=https://sts3-dev-kv-${UNIQUE_SUFFIX}.vault.azure.net/
AZURE_STORAGE_ACCOUNT=sts3devstorage${UNIQUE_SUFFIX}
AZURE_STORAGE_CONTAINER=audio-files

# Application Configuration
ENVIRONMENT=production
LOG_LEVEL=INFO
REDIS_URL=redis://localhost:6379

# CORS Configuration (will be updated with actual frontend domain)
CORS_ORIGINS=["https://sts3-dev-vm-${UNIQUE_SUFFIX}.israelcentral.cloudapp.azure.com"]

# Performance Configuration for Zero Latency
UVICORN_WORKERS=2
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# Audio Processing Configuration - Optimized for Zero Latency
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_SIZE=1024
MAX_AUDIO_DURATION=300

# API Rate Limiting - Optimized for Single User Testing
DEEPGRAM_MAX_CONCURRENT=3
DEEPL_RATE_LIMIT=50
AZURE_TTS_RATE_LIMIT=25

# Azure Speech Configuration
AZURE_SPEECH_REGION=germanywestcentral

# Performance Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
